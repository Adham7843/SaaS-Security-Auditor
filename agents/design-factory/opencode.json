{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "design-factory": {
      "mode": "primary",
      "model": "opencode/deepseek-v4-flash-free",
      "temperature": 0.2,
      "steps": 200,
      "permission": {
        "read": { "*": "allow" },
        "edit": { "brands/*": "allow", "agents/design-factory/*": "allow" },
        "write": { "brands/*/docs/*": "allow", "brands/*/DESIGN.md": "allow" },
        "bash": { "*": "ask" },
        "grep": { "*": "allow" },
        "glob": { "*": "allow" },
        "skill": { "*": "allow" },
        "task": { "explorer": "allow", "general": "allow", "*": "deny" },
        "doom_loop": "ask"
      },
      "prompt": "{file:./AGENT.md}",
      "description": "Design Factory — senior web designer with 60+ skills",
      "color": "#9B59B6"
    }
  },
  "skills": {
    "sources": [
      { "path": "./.opencode/skills", "recursive": true }
    ],
    "enable": [
      "app-initializer",
      "mobile-app-testing",
      "mobile-app-ui-design",
      "mobile-app-security-testing",
      "maestro-mobile-testing",
      "react-native-expert",
      "react-native-best-practices",
      "react-native-design",
      "react-native-architecture",
      "vercel-react-native-skills",
      "ckm-design",
      "gsap-plugins",
      "gsap-react",
      "gsap-scrolltrigger",
      "gsap-timeline",
      "impeccable",
      "motion-framer",
      "react-spring-physics",
      "ui-animation",
      "ui-ux-pro-max",
      "shape",
      "clarify",
      "distill",
      "colorize",
      "typeset",
      "layout",
      "critique",
      "polish",
      "adapt",
      "animate",
      "audit",
      "bolder",
      "delight",
      "optimize",
      "overdrive",
      "quieter",
      "ckm-brand",
      "ckm-ui-styling",
      "ckm-design-system",
      "ckm-slides",
      "ckm-banner-design",
      "ui-design",
      "ui-audit",
      "typography-audit",
      "copywriting",
      "agent-native",
      "agent-skills-creator",
      "autoship",
      "blog-post",
      "define-architecture",
      "docs-writing",
      "mermaid-mind-map",
      "optimise-seo",
      "presentation-creator",
      "readme-creator",
      "scaffold-cli",
      "scaffold-nextjs",
      "threejs-webgl",
      "react-three-fiber",
      "babylonjs-engine",
      "playcanvas-engine",
      "animejs",
      "lottie-animations",
      "rive-interactive",
      "spline-interactive",
      "pixijs-2d",
      "aframe-webxr",
      "locomotive-scroll",
      "scroll-reveal-libraries",
      "blender-web-pipeline",
      "substance-3d-texturing",
      "gsap-core",
      "gsap-frameworks",
