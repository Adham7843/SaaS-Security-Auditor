# SaaS-Security-Auditor — Environment Variables
# Copy to .env and fill in your values.

# Target brand
BRAND_NAME=
TARGET_URL=
TARGET_DIR=

# Reporting
OUTPUT_DIR=output/reports
REPORT_FORMATS=markdown,json,html

# Scanner config
SEVERITY_THRESHOLD=low
TIMEOUT_SECONDS=300

# GitHub (for PR creation when auto-fixing)
GITHUB_TOKEN=
GITHUB_REPO=

# Slack webhook for alerts
SLACK_WEBHOOK_URL=
