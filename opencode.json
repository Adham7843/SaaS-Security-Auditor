{
  "$schema": "https://opencode.ai/config.json",
  "schema_version": "1.0.0",
  "agents": {
    "saas-security-auditor": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "system_prompt": "{file:./AGENT.md}",
      "permissions": {
        "read": {
          "*": "allow",
          "brands/*/.env": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "brands/*/brand.yaml": "allow"
        },
        "bash": {
          "python scripts/run_scan*": "allow",
          "python scripts/scan_all*": "allow",
          "python scripts/run_fix*": "allow",
          "git *": "allow",
          "gh *": "ask",
          "*": "ask"
        },
        "grep": {
          "*": "allow"
        },
        "glob": {
          "*": "allow"
        },
        "webfetch": {
          "*": "allow"
        },
        "doom_loop": "ask"
      },
      "mcps": [
        "filesystem",
        "websearch",
        "gh_grep"
      ],
      "skills": [],
      "description": "SaaS Security Auditor — scans brands for vulnerabilities and applies automated fixes"
    },
    "saas-scanner": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "system_prompt": "You run security scans on SaaS brands. Use python scripts/run_scan.py to scan a brand.",
      "permissions": {
        "bash": {
          "python scripts/run_scan*": "allow",
          "*": "deny"
        },
        "read": {
          "brands/*": "allow",
          "config/*": "allow",
          "*": "deny"
        },
        "edit": {
          "*": "deny"
        }
      },
      "mcps": [],
      "hidden": true,
      "description": "Scanner sub-agent — runs scans only"
    },
    "saas-fixer": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "system_prompt": "You apply automated fixes to vulnerabilities found by scans. Use python scripts/run_fix.py to apply fixes.",
      "permissions": {
        "bash": {
          "python scripts/run_fix*": "allow",
          "*": "deny"
        },
        "read": {
          "output/reports/*": "allow",
          "*": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "*": "deny"
        }
      },
      "mcps": [],
      "hidden": true,
      "description": "Fixer sub-agent — applies auto-fixes"
    },
    "distribution-classifier": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "system_prompt": "{file:./agents/distribution-classifier/AGENT.md}",
      "permissions": {
        "read": { "*": "allow" },
        "edit": { "output/reports/*": "allow" },
        "bash": {
          "python scripts/classify_results*": "allow",
          "python scripts/distribute_findings*": "allow",
          "*": "ask"
        },
        "grep": { "*": "allow" },
        "glob": { "*": "allow" },
        "doom_loop": "deny"
      },
      "mcps": ["filesystem"],
      "description": "Distribution Classifier — classify and route security findings"
    },
    "spec-designer": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "system_prompt": "{file:./agents/spec-designer/AGENT.md}",
      "fallback_chain": ["opencode/gpt-5-nano"],
      "permissions": {
        "read": {
          "brands/*": "allow",
          "output/reports/*": "allow",
          "src/*": "allow",
          "config/*": "allow",
          "*": "ask"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "brands/*/brand.yaml": "allow",
          "*": "deny"
        },
        "bash": {
          "python scripts/run_scan*": "allow",
          "python scripts/run_fix*": "allow",
          "python scripts/classify_results*": "allow",
          "*": "ask"
        },
        "grep": { "brands/*": "allow", "*": "deny" },
        "glob": { "brands/*": "allow", "src/*": "allow", "*": "deny" },
        "doom_loop": "ask"
      },
      "mcps": ["filesystem", "websearch"],
      "skills": [],
      "description": "Spec Designer — turn security findings into structured specs and tasks"
    },
    "design-factory": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "system_prompt": "{file:./agents/design-factory/AGENT.md}",
      "permissions": {
        "read": { "*": "allow" },
        "edit": { "brands/*": "allow", "agents/design-factory/*": "allow" },
        "write": { "brands/*/docs/*": "allow", "brands/*/DESIGN.md": "allow" },
        "bash": { "*": "ask" },
        "grep": { "*": "allow" },
        "glob": { "*": "allow" },
        "skill": { "*": "allow" },
        "doom_loop": "ask"
      },
      "skills": {
        "sources": [
          { "path": "./agents/design-factory/.opencode/skills", "recursive": true }
        ],
        "enable": [
          "shape", "clarify", "distill", "colorize", "typeset", "layout",
          "critique", "polish", "impeccable", "ui-ux-pro-max",
          "ckm-design", "ckm-brand", "ckm-ui-styling", "ckm-design-system",
          "gsap-plugins", "gsap-react", "gsap-scrolltrigger", "gsap-timeline",
          "motion-framer", "react-spring-physics", "ui-animation",
          "threejs-webgl", "react-three-fiber", "babylonjs-engine",
          "copywriting", "ui-design", "ui-audit", "typography-audit",
          "app-initializer", "docs-writing", "presentation-creator",
          "modern-web-design", "animate"
        ]
      },
      "mcps": ["filesystem", "websearch"],
      "description": "Design Factory — senior web designer with 60+ skills",
      "color": "#9B59B6"
    }
  },
  "mcps": {
    "filesystem": {
      "type": "builtin",
      "enabled": true,
      "description": "Read and write files in the project"
    },
    "websearch": {
      "type": "builtin",
      "enabled": true,
      "description": "Search the web for CVE details and security advisories"
    },
    "gh_grep": {
      "type": "builtin",
      "enabled": true,
      "description": "Search GitHub for known vulnerability patterns"
    }
  }
}
