{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "saas-security-auditor": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "prompt": "{file:./AGENT.md}",
      "permission": {
        "read": {
          "*": "allow",
          "brands/*/.env": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "brands/*/brand.yaml": "allow"
        },
        "bash": {
          "python scripts/run_scan*": "allow",
          "python scripts/scan_all*": "allow",
          "python scripts/run_fix*": "allow",
          "git *": "allow",
          "gh *": "ask",
          "*": "ask"
        },
        "grep": {
          "*": "allow"
        },
        "glob": {
          "*": "allow"
        },
        "webfetch": "allow",
        "doom_loop": "ask"
      },
      "mcp": [
        "filesystem",
        "websearch",
        "gh_grep"
      ],
      "description": "SaaS Security Auditor — scans brands for vulnerabilities and applies automated fixes"
    },
    "saas-scanner": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "prompt": "You run security scans on SaaS brands. Use python scripts/run_scan.py to scan a brand.",
      "permission": {
        "bash": {
          "python scripts/run_scan*": "allow",
          "*": "deny"
        },
        "read": {
          "brands/*": "allow",
          "config/*": "allow",
          "*": "deny"
        },
        "edit": {
          "*": "deny"
        }
      },
      "hidden": true,
      "description": "Scanner sub-agent — runs scans only"
    },
    "saas-fixer": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "prompt": "You apply automated fixes to vulnerabilities found by scans. Use python scripts/run_fix.py to apply fixes.",
      "permission": {
        "bash": {
          "python scripts/run_fix*": "allow",
          "*": "deny"
        },
        "read": {
          "output/reports/*": "allow",
          "*": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "*": "deny"
        }
      },
      "hidden": true,
      "description": "Fixer sub-agent — applies auto-fixes"
    },
    "distribution-classifier": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "prompt": "{file:./agents/distribution-classifier/AGENT.md}",
      "permission": {
        "read": { "*": "allow" },
        "edit": { "output/reports/*": "allow" },
        "bash": {
          "python scripts/classify_results*": "allow",
          "python scripts/distribute_findings*": "allow",
          "*": "ask"
        },
        "grep": { "*": "allow" },
        "glob": { "*": "allow" },
        "doom_loop": "deny"
      },
      "mcp": ["filesystem"],
      "description": "Distribution Classifier — classify and route security findings"
    },
    "spec-designer": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "prompt": "{file:./agents/spec-designer/AGENT.md}",
      "permission": {
        "read": {
          "brands/*": "allow",
          "output/reports/*": "allow",
          "src/*": "allow",
          "config/*": "allow",
          "*": "ask"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "brands/*/brand.yaml": "allow",
          "*": "deny"
        },
        "bash": {
          "python scripts/run_scan*": "allow",
          "python scripts/run_fix*": "allow",
          "python scripts/classify_results*": "allow",
          "*": "ask"
        },
        "grep": { "brands/*": "allow", "*": "deny" },
        "glob": { "brands/*": "allow", "src/*": "allow", "*": "deny" },
        "doom_loop": "ask"
      },
      "mcp": ["filesystem", "websearch"],
      "description": "Spec Designer — turn security findings into structured specs and tasks"
    },
    "design-factory": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "prompt": "{file:./agents/design-factory/AGENT.md}",
      "permission": {
        "read": { "*": "allow" },
        "edit": { "brands/*": "allow", "agents/design-factory/*": "allow" },
        "write": { "brands/*/docs/*": "allow", "brands/*/DESIGN.md": "allow" },
        "bash": { "*": "ask" },
        "grep": { "*": "allow" },
        "glob": { "*": "allow" },
        "skill": { "*": "allow" },
        "doom_loop": "ask"
      },
      "skill": {
        "sources": [
          { "path": "./agents/design-factory/.opencode/skills", "recursive": true }
        ],
        "enable": [
          "shape", "clarify", "distill", "colorize", "typeset", "layout",
          "critique", "polish", "impeccable", "ui-ux-pro-max",
          "ckm-design", "ckm-brand", "ckm-ui-styling", "ckm-design-system",
          "gsap-plugins", "gsap-react", "gsap-scrolltrigger", "gsap-timeline",
          "motion-framer", "react-spring-physics", "ui-animation",
          "threejs-webgl", "react-three-fiber", "babylonjs-engine",
          "copywriting", "ui-design", "ui-audit", "typography-audit",
          "app-initializer", "docs-writing", "presentation-creator",
          "modern-web-design", "animate"
        ]
      },
      "mcp": ["filesystem", "websearch"],
      "description": "Design Factory — senior web designer with 60+ skills",
      "color": "#9B59B6"
    },
    "business-cloner": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "prompt": "{file:./agents/business-cloner/AGENT.md}",
      "permission": {
        "read": {
          "brands/*": "allow",
          "output/*": "allow",
          "*.py": "allow",
          "*.md": "allow",
          "*.json": "allow",
          "*.yaml": "allow",
          "F:/Notes/Second_Brain/**": "allow",
          "F:/Notes/Tools/**": "allow",
          "*": "deny"
        },
        "edit": {
          "brands/*": "allow",
          "output/*": "allow",
          "*": "deny"
        },
        "bash": {
          "python pipeline.py *": "allow",
          "pip install *": "ask",
          "npm install *": "ask",
          "playwright install *": "ask",
          "npx stackmd *": "allow",
          "mkdir *": "allow",
          "*": "deny"
        },
        "grep": "allow",
        "glob": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "question": "allow",
        "task": "allow",
        "external_directory": {
          "F:/Notes/Second_Brain/**": "allow",
          "F:/Notes/Tools/**": "allow",
          "*": "ask"
        },
        "doom_loop": "ask"
      },
      "mcp": ["filesystem", "websearch"],
      "description": "Business Cloner — clone and extract full business intelligence from any SaaS website"
    },
    "repo-scanner": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "prompt": "{file:./agents/repo-scanner/AGENT.md}",
      "permission": {
        "read": "allow",
        "bash": {
          "python F:/Notes/Projects/Automations_Dev/agents/repo-scanner/pipeline.py *": "allow",
          "git clone *": "allow",
          "*": "deny"
        },
        "edit": {
          "output/*": "allow",
          "*": "deny"
        },
        "glob": "allow",
        "grep": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "external_directory": "allow"
      },
      "description": "Repo Scanner — fetch + analyze any GitHub/npm/PyPI repo with knowledge graph + AI"
    }
  }
}
