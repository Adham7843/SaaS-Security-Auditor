{
  "$schema": "https://opencode.ai/config.json",
  "schema_version": "1.0.0",
  "agents": {
    "saas-security-auditor": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "high",
      "system_prompt": "{file:./AGENT.md}",
      "permissions": {
        "read": {
          "*": "allow",
          "brands/*/.env": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "brands/*/brand.yaml": "allow"
        },
        "bash": {
          "python scripts/run_scan*": "allow",
          "python scripts/scan_all*": "allow",
          "python scripts/run_fix*": "allow",
          "git *": "allow",
          "gh *": "ask",
          "*": "ask"
        },
        "grep": {
          "*": "allow"
        },
        "glob": {
          "*": "allow"
        },
        "webfetch": {
          "*": "allow"
        },
        "doom_loop": "ask"
      },
      "mcps": [
        "filesystem",
        "websearch",
        "gh_grep"
      ],
      "skills": [],
      "description": "SaaS Security Auditor — scans brands for vulnerabilities and applies automated fixes"
    },
    "saas-scanner": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "system_prompt": "You run security scans on SaaS brands. Use python scripts/run_scan.py to scan a brand.",
      "permissions": {
        "bash": {
          "python scripts/run_scan*": "allow",
          "*": "deny"
        },
        "read": {
          "brands/*": "allow",
          "config/*": "allow",
          "*": "deny"
        },
        "edit": {
          "*": "deny"
        }
      },
      "mcps": [],
      "hidden": true,
      "description": "Scanner sub-agent — runs scans only"
    },
    "saas-fixer": {
      "model": "opencode/deepseek-v4-flash-free",
      "variant": "medium",
      "system_prompt": "You apply automated fixes to vulnerabilities found by scans. Use python scripts/run_fix.py to apply fixes.",
      "permissions": {
        "bash": {
          "python scripts/run_fix*": "allow",
          "*": "deny"
        },
        "read": {
          "output/reports/*": "allow",
          "*": "deny"
        },
        "edit": {
          "brands/*/src/*": "allow",
          "*": "deny"
        }
      },
      "mcps": [],
      "hidden": true,
      "description": "Fixer sub-agent — applies auto-fixes"
    }
  },
  "mcps": {
    "filesystem": {
      "type": "builtin",
      "enabled": true,
      "description": "Read and write files in the project"
    },
    "websearch": {
      "type": "builtin",
      "enabled": true,
      "description": "Search the web for CVE details and security advisories"
    },
    "gh_grep": {
      "type": "builtin",
      "enabled": true,
      "description": "Search GitHub for known vulnerability patterns"
    }
  }
}
